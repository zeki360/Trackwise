/**
 * @fileoverview Firestore Security Rules for TrackWise application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model, where users can only manage their own data,
 * specifically their profiles and the issues they have reported.
 *
 * Data Structure:
 * - All user data is stored under `/users/{userId}`.
 * - Issues reported by a user are stored under `/users/{userId}/issues/{issueId}`.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own user documents.
 * - Users can only create, read, update, and delete issues that they have reported.
 * - Listing all users is disallowed for security reasons.
 * - The 'reportedBy' field is denormalized in the Issue document to avoid `get()` calls in security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles. Only the user themselves can create, read, update, or delete their profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create their profile at /users/user_abc.
     * @allow (get) - Authenticated user with UID 'user_abc' can read their profile at /users/user_abc.
     * @allow (update) - Authenticated user with UID 'user_abc' can update their profile at /users/user_abc.
     * @allow (delete) - Authenticated user with UID 'user_abc' can delete their profile at /users/user_abc.
     * @deny (create) - Authenticated user with UID 'user_xyz' cannot create a profile at /users/user_abc.
     * @deny (get) - Authenticated user with UID 'user_xyz' cannot read the profile at /users/user_abc.
     * @deny (update) - Authenticated user with UID 'user_xyz' cannot update the profile at /users/user_abc.
     * @deny (delete) - Authenticated user with UID 'user_xyz' cannot delete the profile at /users/user_abc.
     * @principle Enforces user-ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not permitted.
      allow create: if isSelfCreation(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to issues reported by users. Only the user who reported the issue can create, read, update, or delete it.
     * @path /users/{userId}/issues/{issueId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create an issue under /users/user_abc/issues/issue_123 if reportedBy matches user_abc.
     * @allow (get) - Authenticated user with UID 'user_abc' can read an issue under /users/user_abc/issues/issue_123.
     * @allow (update) - Authenticated user with UID 'user_abc' can update an issue under /users/user_abc/issues/issue_123.
     * @allow (delete) - Authenticated user with UID 'user_abc' can delete an issue under /users/user_abc/issues/issue_123.
     * @deny (create) - Authenticated user with UID 'user_xyz' cannot create an issue under /users/user_abc/issues/issue_123.
     * @deny (get) - Authenticated user with UID 'user_xyz' cannot read the issue under /users/user_abc/issues/issue_123.
     * @deny (update) - Authenticated user with UID 'user_xyz' cannot update the issue under /users/user_abc/issues/issue_123.
     * @deny (delete) - Authenticated user with UID 'user_xyz' cannot delete the issue under /users/user_abc/issues/issue_123.
     * @principle Enforces user-ownership for issues reported by users.
     */
    match /users/{userId}/issues/{issueId} {
      allow get: if isIssueOwner(userId);
      allow list: if isIssueOwner(userId);
      allow create: if isSignedIn() && isIssueCreationByOwner();
      allow update: if isExistingIssueOwner();
      allow delete: if isExistingIssueOwner();
    }

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isSelfCreation(userId) {
        return isSignedIn() && request.auth.uid == userId;
    }

    function isIssueCreationByOwner() {
      return request.resource.data.reportedBy == request.auth.uid;
    }

    function isExistingIssueOwner() {
      return request.auth.uid == resource.data.reportedBy;
    }

    function isIssueOwner(userId) {
        return request.auth.uid == userId;
    }
  }
}