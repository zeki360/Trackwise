
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own user profile document.
    // The `request.auth.uid` is the UID of the user making the request.
    // The `{userId}` wildcard matches the document ID.
    // This rule ensures a user can only access their own document in the 'users' collection.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // You will need to add rules for your other collections (e.g., 'issues') here.
    // For now, this placeholder denies access to all other collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
